/* 设备名称显示区域 */
.device-name-display {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-right: 20rpx;
  padding: 8rpx 15rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  border: 1rpx solid rgba(102, 126, 234, 0.2);
  min-width: 1rpx;
  max-width: 320rpx;
  text-align: right;
  flex-shrink: 1;
  overflow: hidden;
}

  .device-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 3rpx;
  max-width: 300rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.3;
}

.device-id {
  font-size: 20rpx;
  color: #888;
  font-family: 'Courier New', monospace;
  background: rgba(0, 0, 0, 0.05);
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  max-width: 300rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.3;
}

.status-right {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
  min-width: 0;
}

.setting-icon {
  margin-left: 10rpx;
  padding: 8rpx;
  border-radius: 50%;
  background: #f0f0f0;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s;
  flex-shrink: 0;
}

.setting-icon:active {
  background: #e0e0e0;
  transform: scale(0.95);
}

.setting-icon .icon {
  font-size: 24rpx;
}

/* 警报面板样式 */
.alarm-panel {
  position: fixed;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  background: linear-gradient(135deg, #ff4d4f, #ff7875);
  border-radius: 20rpx;
  box-shadow: 0 10rpx 40rpx rgba(255, 77, 79, 0.4);
  z-index: 1001;
  animation: slideDown 0.3s ease-out;
  overflow: hidden;
}

@keyframes slideDown {
  from { transform: translateY(-100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.alarm-content {
  padding: 30rpx;
}

.alarm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.alarm-icon {
  font-size: 40rpx;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.alarm-title {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  flex: 1;
  margin-left: 20rpx;
}

.close-btn {
  color: white;
  font-size: 28rpx;
  padding: 10rpx;
  cursor: pointer;
  opacity: 0.8;
}

.close-btn:active {
  opacity: 1;
  transform: scale(1.2);
}

.alarm-body {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 15rpx;
  padding: 25rpx;
  backdrop-filter: blur(10rpx);
}

.alarm-message {
  display: block;
  font-size: 28rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.alarm-data {
  display: flex;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 20rpx;
}

.alarm-item {
  text-align: center;
  flex: 1;
}

.alarm-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 8rpx;
}

.alarm-value {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  font-family: 'Arial', sans-serif;
}

.alarm-value.warning {
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.alarm-time {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-family: 'Arial', sans-serif;
  margin-top: 5rpx;
}

/* 其他原有样式保持不变 */
.welcome-screen {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.welcome-container {
  background: white;
  width: 85%;
  max-width: 600rpx;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.3);
  text-align: center;
}

.welcome-header {
  margin-bottom: 50rpx;
}

.welcome-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.3;
}

.welcome-subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.4;
}

.welcome-form {
  margin-bottom: 50rpx;
}

.form-group {
  margin-bottom: 40rpx;
  text-align: left;
}

.form-label {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.form-input {
  border: 3rpx solid #e0e0e0;
  border-radius: 15rpx;
  padding: 25rpx;
  font-size: 32rpx;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 10rpx;
  color: #333;
  background-color: #fff;
  min-height: 100rpx;
  line-height: 1.4;
  -webkit-text-fill-color: #333;
  opacity: 1;
}

.form-input:focus {
  border-color: #667eea;
  outline: none;
  box-shadow: 0 0 0 2rpx rgba(102, 126, 234, 0.2);
  background-color: #f8f9ff;
}

.placeholder {
  color: #999;
  font-size: 28rpx;
  line-height: 1.4;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  line-height: 1.4;
}

.form-tips {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 25rpx;
  text-align: left;
  border-left: 6rpx solid #667eea;
  margin-top: 30rpx;
}

.tip-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.tip-content {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.welcome-actions {
  margin-top: 40rpx;
}

.confirm-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  padding: 25rpx 0;
  width: 100%;
  border: none;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s;
  line-height: 1.4;
}

.confirm-btn:active {
  transform: scale(0.98);
  box-shadow: 0 5rpx 20rpx rgba(102, 126, 234, 0.4);
}

.confirm-btn[disabled] {
  background: #ccc;
  box-shadow: none;
  color: #999;
}

.btn-text {
  font-weight: bold;
  line-height: 1.4;
}

.setting-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.setting-content {
  background: white;
  width: 85%;
  max-width: 650rpx;
  border-radius: 20rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.2);
}

.setting-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #333;
  line-height: 1.3;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  font-weight: 500;
  line-height: 1.4;
}

.device-input {
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 25rpx;
  font-size: 32rpx;
  width: 100%;
  box-sizing: border-box;
  color: #333;
  background-color: #fff;
  min-height: 90rpx;
  line-height: 1.4;
  -webkit-text-fill-color: #333;
  opacity: 1;
}

.device-input:focus {
  border-color: #667eea;
  outline: none;
  box-shadow: 0 0 0 2rpx rgba(102, 126, 234, 0.2);
  background-color: #f8f9ff;
}

.input-hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  line-height: 1.4;
}

.button-group {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-cancel, .btn-save {
  flex: 1;
  border-radius: 10rpx;
  font-size: 28rpx;
  padding: 20rpx;
  border: none;
  transition: all 0.3s;
  line-height: 1.4;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-cancel:active {
  background: #e0e0e0;
}

.btn-save {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-save:active {
  transform: scale(0.98);
}

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: white;
  padding: 20rpx 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.status-item {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.status-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.status-dot.normal {
  background-color: #52c41a;
  animation: pulseDot 2s infinite;
}

@keyframes pulseDot {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}

.status-dot.error {
  background-color: #f5222d;
  animation: blinkDot 1s infinite;
}

@keyframes blinkDot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.status-text {
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1.4;
  min-width: 60rpx;
}

.update-time {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
  white-space: nowrap;
  margin-right: 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin: 30rpx 0 20rpx 0;
  color: #333;
  padding-left: 10rpx;
  border-left: 6rpx solid #1890ff;
  line-height: 1.4;
}

.first-data-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.data-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.data-item:last-child {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.data-label {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
  line-height: 1.4;
  min-width: 80rpx;
}

.data-value {
  font-size: 40rpx;
  font-weight: bold;
  font-family: 'Arial', sans-serif;
  line-height: 1.4;
}

.data-value.normal {
  color: #52c41a;
}

.data-value.warning {
  color: #f5222d;
  animation: shake 0.5s ease;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-5rpx); }
  20%, 40%, 60%, 80% { transform: translateX(5rpx); }
}

.data-time {
  font-size: 28rpx;
  color: #999;
  font-family: 'Arial', sans-serif;
  line-height: 1.4;
  text-align: right;
  min-width: 150rpx;
}

.stats-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.stats-category {
  margin-bottom: 30rpx;
}

.stats-category:last-child {
  margin-bottom: 0;
}

.stats-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  line-height: 1.4;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.stat-item {
  background: linear-gradient(135deg, #f8f9fa, #e9ecef);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  min-width: 0;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
  font-family: 'Arial', sans-serif;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.list-container {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.list-header {
  display: grid;
  grid-template-columns: 1fr 1fr 2fr;
  background: #1890ff;
  color: white;
  font-weight: bold;
  font-size: 28rpx;
  padding: 20rpx;
}

.header-cell {
  text-align: center;
  padding: 10rpx;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.list-row {
  display: grid;
  grid-template-columns: 1fr 1fr 2fr;
  border-bottom: 1rpx solid #f0f0f0;
  padding: 20rpx;
  align-items: center;
  min-height: 80rpx;
}

.list-row:last-child {
  border-bottom: none;
}

.list-cell {
  text-align: center;
  font-size: 28rpx;
  padding: 10rpx;
  font-family: 'Arial', sans-serif;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.list-cell.normal {
  color: #52c41a;
  font-weight: bold;
}

.list-cell.warning {
  color: #f5222d;
  font-weight: bold;
  animation: pulse 2s infinite;
}

.list-cell.time {
  color: #666;
  font-size: 24rpx;
  min-width: 120rpx;
}

.refresh-area {
  margin: 40rpx 0;
  text-align: center;
}

.refresh-btn {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 20rpx 60rpx;
  box-shadow: 0 4rpx 20rpx rgba(24, 144, 255, 0.3);
  border: none;
  line-height: 1.4;
  min-width: 200rpx;
}

.refresh-btn:active {
  transform: scale(0.98);
}

.btn-text {
  font-weight: bold;
  line-height: 1.4;
}

/* 开关项样式 */
.switch-item {
  border-bottom: none;
  margin-bottom: 0;
  padding-bottom: 0;
}

.switch-wrapper {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

switch {
  transform: scale(0.9);
  transform-origin: right center;
}

.switch-status {
  font-size: 24rpx;
  color: #666;
  min-width: 60rpx;
  text-align: right;
}

/* 开关开启状态文字颜色 */
.switch-wrapper text[class*="switch-status"] {
  color: #666;
}

switch[checked] + .switch-status {
  color: #52c41a;
  font-weight: 500;
}

/* 为switch添加自定义样式 */
switch .wx-switch-input {
  width: 80rpx;
  height: 40rpx;
}

switch .wx-switch-input::before {
  width: 76rpx;
  height: 36rpx;
}

switch .wx-switch-input::after {
  width: 36rpx;
  height: 36rpx;
}

/* 开关开启时的背景色 */
switch.checked .wx-switch-input {
  border-color: #52c41a;
  background-color: #52c41a;
}

/* 开关关闭时的背景色 */
switch:not(.checked) .wx-switch-input {
  border-color: #d9d9d9;
  background-color: #d9d9d9;
}